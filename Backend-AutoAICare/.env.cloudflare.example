# Environment Variables for Tenant Onboarding

# Add these to your Backend-AutoAICare/.env file

# ============================================
# Cloudflare API Configuration
# ============================================

# Get these from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_KEY=your_cloudflare_global_api_key_here
CLOUDFLARE_EMAIL=your_cloudflare_account_email@example.com

# Get Zone ID from: https://dash.cloudflare.com/ → Select domain → Overview (right sidebar)
CLOUDFLARE_ZONE_ID=your_zone_id_for_autoaicare_com

# Base domain for your SaaS
BASE_DOMAIN=autoaicare.com

# ============================================
# How to Get Cloudflare Credentials
# ============================================

# 1. Cloudflare API Key (Global API Key)
#    - Go to: https://dash.cloudflare.com/profile/api-tokens
#    - Scroll to "API Keys" section
#    - Click "View" next to "Global API Key"
#    - Enter your password
#    - Copy the key

# 2. Cloudflare Email
#    - This is the email you use to login to Cloudflare

# 3. Cloudflare Zone ID
#    - Go to: https://dash.cloudflare.com/
#    - Select your domain (autoaicare.com)
#    - Scroll down on the Overview page
#    - Find "Zone ID" in the right sidebar under "API"
#    - Copy the Zone ID

# ============================================
# Alternative: API Token (More Secure)
# ============================================

# Instead of Global API Key, you can create a custom API token with limited permissions:
# 1. Go to: https://dash.cloudflare.com/profile/api-tokens
# 2. Click "Create Token"
# 3. Use "Edit zone DNS" template
# 4. Select your zone (autoaicare.com)
# 5. Create token and copy it

# Then use:
# CLOUDFLARE_API_TOKEN=your_custom_api_token_here
# (Requires updating the Python script to use Bearer token instead of API key)
